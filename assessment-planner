function applyProfile(prof){document.querySelectorAll('.prof-card').forEach(function(el){el.classList.toggle('sel',el.dataset.id===prof.id)});var mr=document.querySelector('input[name="mode"][value="'+prof.mode+'"]');if(mr)mr.checked=true;U.id('plainEnglish').checked=prof.pe;document.body.classList.toggle('pe-mode',prof.pe);U.id('ndFriendly').checked=prof.nd;document.body.classList.toggle('nd-friendly',prof.nd);U.id('dyslexiaMode').checked=prof.dys;document.body.classList.toggle('dyslexia-mode',prof.dys);if(prof.dys){document.documentElement.style.setProperty('--font-size','110%');U.id('fontSize').value=110;U.id('fsVal').textContent='110';document.documentElement.style.setProperty('--line-height','1.80');U.id('lineHeight').value=180;U.id('lhVal').textContent='180'}TIP_CATS.forEach(function(c){var cb=document.querySelector('#tipGrid input[value="'+c.id+'"]');if(cb)cb.checked=prof.tips.indexOf(c.id)!==-1});U.status('setupStatus','Profile "'+prof.label+'" applied.')}
function generatePlan(){var title=U.id('title').value.trim(),atype=U.id('atype').value,startStr=U.id('start').value,dueStr=U.id('due').value;if(!title){U.status('setupStatus','Please enter a title.',true);return}if(!startStr||!dueStr){U.status('setupStatus','Please set both dates.',true);return}var startDate=U.parseD(startStr),dueDate=U.parseD(dueStr);if(dueDate<=startDate){U.status('setupStatus','Due must be after start.',true);return}var mode=getMode(),studyDays=getStudyDays(),stages=BASE[atype]||BASE.Essay,showLOs=U.id('showLOs').checked,activeTips=getActiveTips();var losRaw=U.id('los').value.trim();APP.los=losRaw?LO.parse(losRaw):[];var loMap={};stages.forEach(function(s){loMap[s]=[]});APP.los.forEach(function(lo){var cats=[...new Set(lo.verbs.map(function(v){return LO.BLOOM[v]}))].filter(Boolean);cats.forEach(function(cat){(V2S[cat]||[]).forEach(function(st){if(loMap[st]&&loMap[st].indexOf(lo.code)===-1)loMap[st].push(lo.code)})})});var weights=stages.map(function(s){return/draft|write|create/i.test(s)?2:1}),totalWeight=weights.reduce(function(a,b){return a+b},0);var studyDates=[],cursor=new Date(startDate);while(cursor<dueDate){var dow=cursor.getDay();var isoDay=dow===0?7:dow;if(studyDays.indexOf(isoDay)!==-1)studyDates.push(new Date(cursor));cursor=U.addD(cursor,1)}if(!studyDates.length){U.status('setupStatus','No study days in range.',true);return}var dateIdx=0;var plan=stages.map(function(stage,i){var share=Math.max(1,Math.round(studyDates.length*weights[i]/totalWeight));var chunk=studyDates.slice(dateIdx,dateIdx+share);dateIdx+=share;if(!chunk.length)chunk=[studyDates[studyDates.length-1]];var loTags=showLOs?(loMap[stage]||[]):[];return{id:'stage-'+i,name:stage,startDate:U.fmtD(chunk[0]),endDate:U.fmtD(chunk[chunk.length-1]),tasks:makeTasks(stage,mode,loTags,activeTips).map(function(t,j){return{id:'s'+i+'t'+j,text:t}}),loTags:loTags,hint:(mode!=='Essentials')?(HINTS[stage]||''):''}});APP.plan=plan;APP.checked={};save();renderPlan();U.status('setupStatus','Plan created - '+plan.length+' stages, '+plan.reduce(function(a,s){return a+s.tasks.length},0)+' tasks.')}
function renderPlan(){var plan=APP.plan;if(!plan||!plan.length){U.id('plan').innerHTML='<div class="muted" style="padding:1rem;text-align:center">No plan yet.</div>';U.id('overview').innerHTML='';return}var today=new Date();today.setHours(0,0,0,0);var totalTasks=plan.reduce(function(a,s){return a+s.tasks.length},0);var doneTasks=plan.reduce(function(a,s){return a+s.tasks.filter(function(t){return APP.checked[t.id]}).length},0);var pct=totalTasks?Math.round(doneTasks/totalTasks*100):0;U.id('overview').innerHTML='<div><div class="big">'+plan.length+'</div>Stages</div><div><div class="big">'+totalTasks+'</div>Tasks</div><div><div class="big">'+doneTasks+'</div>Done</div><div><div class="big">'+pct+'%</div>Progress</div><div><div class="big">'+U.niceD(U.parseD(plan[0].startDate))+'</div>Start</div><div><div class="big">'+U.niceD(U.parseD(plan[plan.length-1].endDate))+'</div>End</div>';U.id('plan').innerHTML=plan.map(function(stage){var sd=U.parseD(stage.startDate),ed=U.parseD(stage.endDate);var sc=stage.tasks.filter(function(t){return APP.checked[t.id]}).length;var sp=stage.tasks.length?Math.round(sc/stage.tasks.length*100):0;var allDone=sp===100,isToday=today>=sd&&today<=ed,isOverdue=today>ed&&!allDone;var cls='stage-card';if(allDone)cls+=' done';else if(isOverdue)cls+=' overdue';else if(isToday)cls+=' today';var h='<div class="'+cls+'" role="listitem"><div class="stage-head"><div><div class="stage-title">'+stage.name;if(isToday)h+=' <span class="today-marker">TODAY</span>';if(isOverdue)h+=' <span class="today-marker" style="background:var(--danger)">OVERDUE</span>';h+='</div><div class="stage-dates">'+U.niceD(sd)+' - '+U.niceD(ed)+'</div></div><div style="text-align:right;font-size:.85rem;font-weight:700;color:var(--accent)">'+sp+'%</div></div>';if(stage.loTags&&stage.loTags.length)h+='<div class="lo-badges">'+stage.loTags.map(function(t){return'<span class="pill badge">'+t+'</span>'}).join('')+'</div>';h+='<details class="stage-steps"'+(isToday||isOverdue?' open':'')+' ><summary>Tasks ('+sc+'/'+stage.tasks.length+')</summary><ul class="checklist">';stage.tasks.forEach(function(t){var ck=APP.checked[t.id]?'checked':'';var st=ck?';text-decoration:line-through;opacity:.6':'';h+='<li><input type="checkbox" id="'+t.id+'" data-task="'+t.id+'" '+ck+'><label for="'+t.id+'" style="font-weight:400;margin:0;cursor:pointer'+st+'">'+t.text+'</label></li>'});h+='</ul>';if(stage.hint)h+='<div class="hint">Tip: '+stage.hint+'</div>';h+='</details><div class="progress-bar"><div class="fill" style="width:'+sp+'%"></div></div></div>';return h}).join('');document.querySelectorAll('#plan input[type="checkbox"]').forEach(function(cb){cb.addEventListener('change',function(e){APP.checked[e.target.dataset.task]=e.target.checked;save();renderPlan()})})}
function reflowPlan(){if(!APP.plan)return;var today=new Date();today.setHours(0,0,0,0);var dueStr=U.id('due').value;if(!dueStr){U.status('plannerStatus','Set a due date first.',true);return}var dueDate=U.parseD(dueStr),studyDays=getStudyDays();var remaining=APP.plan.filter(function(s){return!s.tasks.every(function(t){return APP.checked[t.id]})});if(!remaining.length){U.status('plannerStatus','All tasks complete!');return}var studyDates=[],cursor=new Date(today);while(cursor<dueDate){var dow=cursor.getDay();var isoDay=dow===0?7:dow;if(studyDays.indexOf(isoDay)!==-1)studyDates.push(new Date(cursor));cursor=U.addD(cursor,1)}if(!studyDates.length){U.status('plannerStatus','No study days remain.',true);return}var idx=0,per=Math.max(1,Math.floor(studyDates.length/remaining.length));remaining.forEach(function(stage){var chunk=studyDates.slice(idx,idx+per);idx+=per;if(chunk.length){stage.startDate=U.fmtD(chunk[0]);stage.endDate=U.fmtD(chunk[chunk.length-1])}});save();renderPlan();U.status('plannerStatus','Reflowed '+remaining.length+' stages.')}
function exportICS(){if(!APP.plan){U.status('plannerStatus','Create a plan first.',true);return}var gran=U.id('icsGranularity').value,title=U.id('title').value||'Assessment';var uid=function(){return Math.random().toString(36).slice(2)+Date.now().toString(36)+'@planner'};var events='';if(gran==='major'){APP.plan.forEach(function(s){events+='BEGIN:VEVENT\r\nUID:'+uid()+'\r\nDTSTART:'+U.icsDate(U.parseD(s.startDate))+'\r\nDTEND:'+U.icsDate(U.addD(U.parseD(s.endDate),1))+'\r\nSUMMARY:'+title+' - '+s.name+'\r\nEND:VEVENT\r\n'})}else{APP.plan.forEach(function(s){s.tasks.forEach(function(t,i){var d=U.addD(U.parseD(s.startDate),i);events+='BEGIN:VEVENT\r\nUID:'+uid()+'\r\nDTSTART:'+U.icsDate(d)+'\r\nSUMMARY:'+s.name+': '+t.text+'\r\nEND:VEVENT\r\n'})})}var cal='BEGIN:VCALENDAR\r\nVERSION:2.0\r\nPRODID:-//AssessmentPlanner//EN\r\n'+events+'END:VCALENDAR';var blob=new Blob([cal],{type:'text/calendar'});var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=(title.replace(/\s+/g,'_'))+'.ics';document.body.appendChild(a);a.click();document.body.removeChild(a);U.status('plannerStatus','Calendar downloaded.')}
function copyShareLink(){try{var data={t:U.id('title').value,a:U.id('atype').value,s:U.id('start').value,d:U.id('due').value,m:getMode(),lo:U.id('los').value};var url=location.origin+location.pathname+'#plan='+btoa(unescape(encodeURIComponent(JSON.stringify(data))));navigator.clipboard.writeText(url).then(function(){U.status('plannerStatus','Share link copied!')})}catch(e){U.status('plannerStatus','Could not copy.',true)}}
function loadShareLink(){try{var h=location.hash;if(h.indexOf('#plan=')!==0)return false;var d=JSON.parse(decodeURIComponent(escape(atob(h.slice(6)))));if(d.t)U.id('title').value=d.t;if(d.a)U.id('atype').value=d.a;if(d.s)U.id('start').value=d.s;if(d.d)U.id('due').value=d.d;if(d.lo)U.id('los').value=d.lo;U.status('setupStatus','Loaded from shared link.');return true}catch(e){return false}}
