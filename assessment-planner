function load(){try{var d=JSON.parse(localStorage.getItem(STORE_KEY));if(!d)return false;if(d.title)U.id('title').value=d.title;if(d.atype)U.id('atype').value=d.atype;if(d.startD)U.id('start').value=d.startD;if(d.dueD)U.id('due').value=d.dueD;if(d.context)U.id('context').value=d.context;if(d.losRaw)U.id('los').value=d.losRaw;if(d.checked)APP.checked=d.checked;if(d.plan){APP.plan=d.plan;renderPlan()}return true}catch(e){return false}}
